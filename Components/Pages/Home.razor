@page "/"
@using Microsoft.EntityFrameworkCore
@using OsDigitalMVP.Models
@using OsDigitalMVP.Data
@inject HttpClient Http
@inject AppDbContext Db
@rendermode InteractiveServer

<PageTitle>Nova OS Digital</PageTitle>

<div class="container" style="max-width: 600px; margin-top: 50px;">
    <h3 style="font-weight: 300; margin-bottom: 30px;">Criar nova ordem de serviço digital</h3>

    <div class="card" style="border: 1px solid #e2e8f0; border-radius: 12px; padding: 25px; box-shadow: none;">
        <div class="mb-3">
            <input @bind="novaOS.CEP" @onblur="ConsultarCEP" class="form-control" placeholder="Digite seu CEP" />
        </div>
        <div class="mb-3">
            <input @bind="novaOS.Endereco" class="form-control" placeholder="Ex: Rua Alameda" readonly="@buscando" />
        </div>
        <div class="mb-3">
            <input @bind="novaOS.CNPJ" 
                   @oninput="OnCnpjInput" 
                   class="form-control" 
                   placeholder="CNPJ (AA.AAA.AAA/AAAA-DV)" 
                   maxlength="18" />
        </div>
        <div class="mb-3">
            <input @bind="novaOS.ClienteNome" class="form-control" placeholder="Nome do Cliente" />
        </div>
        <div class="mb-3">
            <textarea @bind="novaOS.Descricao" class="form-control" placeholder="Descrição do serviço"></textarea>
        </div>
        <button class="btn btn-primary w-100" style="background: #000; border: none; border-radius: 8px; height: 45px;" @onclick="Salvar">
            CRIAR OS
        </button>
    </div>

    @if (ordens != null && ordens.Any())
    {
        <hr class="my-5" style="border-top: 1px solid #e2e8f0;" />
        <h4 style="font-weight: 300; margin-bottom: 20px;">Útimas ordens criadas</h4>
        <div class="table-responsive">
            <table class="table" style="font-size: 0.9rem;">
                <thead>
                    <tr style="color: #64748b;">
                        <th>Cliente</th>
                        <th>CNPJ</th>
                        <th>ID</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var os in ordens)
                    {
                        <tr>
                            <td>@os.ClienteNome</td>
                            <td>@os.CNPJ</td>
                            <td class="text-muted">#@os.Id</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private OrdemServico novaOS = new();
    private List<OrdemServico> ordens = new();
    private bool buscando = false;

    private void OnCnpjInput(ChangeEventArgs e)
    {
        string input = e.Value?.ToString() ?? "";
    
        // Remove tudo que não for letra ou número
        string clean = new string(input.Where(c => char.IsLetterOrDigit(c)).ToArray());

        // Limita a 14 caracteres (tamanho padrão do CNPJ)
        if (clean.Length > 14) clean = clean.Substring(0, 14);

        // Aplica a máscara: XX.XXX.XXX/XXXX-XX
        string formatted = clean;
        if (clean.Length > 2) formatted = formatted.Insert(2, ".");
        if (clean.Length > 5) formatted = formatted.Insert(6, ".");
        if (clean.Length > 8) formatted = formatted.Insert(10, "/");
        if (clean.Length > 12) formatted = formatted.Insert(15, "-");

        novaOS.CNPJ = formatted.ToUpper();
    }
    
    protected override async Task OnInitializedAsync()
    {
        await CarregarOrdens();
    }

    private async Task CarregarOrdens()
    {
        ordens = await Db.OrdensServico
            .AsNoTracking()
            .OrderByDescending(x => x.Id)
            .ToListAsync<OrdemServico>(); 
    }

    private async Task ConsultarCEP()
    {
        var cep = novaOS.CEP?.Replace("-", "").Trim();
        if (cep?.Length == 8)
        {
            buscando = true;
            try 
            {
                var result = await Http.GetFromJsonAsync<ViaCepResult>($"https://viacep.com.br/ws/{cep}/json/");
                if (result != null && string.IsNullOrEmpty(result.Erro))
                {
                    novaOS.Endereco = $"{result.Logradouro}, {result.Bairro} - {result.Localidade}/{result.Uf}";
                }
            } 
            finally 
            { 
                buscando = false; 
                StateHasChanged();
            }
        }
    }

    private async Task Salvar()
    {
        if (string.IsNullOrWhiteSpace(novaOS.ClienteNome)) return;

        Db.OrdensServico.Add(novaOS);
        await Db.SaveChangesAsync();
        
        novaOS = new OrdemServico();
        await CarregarOrdens(); 
    }

    public class ViaCepResult
    {
        public string Logradouro { get; set; } = "";
        public string Bairro { get; set; } = "";
        public string Localidade { get; set; } = "";
        public string Uf { get; set; } = "";
        public string Erro { get; set; } = "";
    }
}